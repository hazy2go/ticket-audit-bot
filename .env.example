# Discord bot token (Bot → Reset Token in Dev Portal)
BOT_TOKEN=

# Guild to audit
GUILD_ID=

# Comma-separated category IDs that contain ticket channels.
# Optional — if empty, the bot falls back to name heuristics
# (parent category named tickets/support/modmail, or channel name
# starting with ticket-/support-).
TICKET_CATEGORY_IDS=

# Optional: channel ID where audit reports are posted as embeds.
# If empty, reports print to console only (good for first run / dry test).
REPORT_CHANNEL_ID=

# How often to re-run the audit, in milliseconds. Default: 6h.
AUDIT_INTERVAL_MS=21600000

# Set to 1 to run the audit once and exit (used by `npm run once`).
AUDIT_ONCE=
